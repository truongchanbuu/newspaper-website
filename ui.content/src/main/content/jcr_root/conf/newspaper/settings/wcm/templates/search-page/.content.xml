<?xml version="1.0" encoding="UTF-8"?>
<!--
  Editable Template: Search Page
  - status=enabled    → visible in the "Create Page" wizard
  - allowedPaths      → only under /content/language-masters (language masters + all language copies)
  - cq:templateType   → inherits behaviours from the base page template type
-->
<jcr:root xmlns:cq="http://www.day.com/jcr/cq/1.0"
          xmlns:jcr="http://www.jcp.org/jcr/1.0"
          jcr:primaryType="cq:Template">
    <jcr:content
        jcr:primaryType="cq:PageContent"
        jcr:title="Search Page"
        jcr:description="Guardian-style search page with text, category, and date filters."
        cq:templateType="/conf/newspaper/settings/wcm/template-types/page"
        allowedPaths="[/content/newspaper/language-masters(/.*)?]"
        ranking="{Long}10"
        status="enabled"/>
</jcr:root>
