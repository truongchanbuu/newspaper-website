<?xml version="1.0" encoding="UTF-8"?>
<!-- Homepage template initial content — copied to every new page created from this template -->
<jcr:root xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
          xmlns:cq="http://www.day.com/jcr/cq/1.0"
          xmlns:jcr="http://www.jcp.org/jcr/1.0"
          xmlns:nt="http://www.jcp.org/jcr/nt/1.0"
          jcr:primaryType="cq:Page">
    <jcr:content
        jcr:primaryType="cq:PageContent"
        sling:resourceType="newspaper/components/structure/homepage">

        <!-- ── XF Header ──────────────────────────────────────────────── -->
        <experiencefragment-header
            jcr:primaryType="nt:unstructured"
            sling:resourceType="newspaper/components/experiencefragment"
            fragmentVariationPath="/content/experience-fragments/newspaper/us/en/site/header/master"/>

        <!-- ── Hero: 2-column carousel zone ────────────────────────────── -->
        <hero
            jcr:primaryType="nt:unstructured"
            sling:resourceType="wcm/foundation/components/responsivegrid">
            <carousel-left
                jcr:primaryType="nt:unstructured"
                sling:resourceType="newspaper/components/content/carousel"
                autoplay="{Boolean}true"
                delay="{Long}5000"/>
            <carousel-right
                jcr:primaryType="nt:unstructured"
                sling:resourceType="newspaper/components/content/carousel"
                autoplay="{Boolean}true"
                delay="{Long}7000"/>
        </hero>

        <!-- ── Latest News: recent articles across all categories ────────── -->
        <latest
            jcr:primaryType="nt:unstructured"
            sling:resourceType="wcm/foundation/components/responsivegrid">
            <news-grid
                jcr:primaryType="nt:unstructured"
                sling:resourceType="newspaper/components/content/articlelisting"
                sectionTitle="Latest News"
                maxItems="{Long}6"/>
        </latest>

        <!-- ── Category Sections ──────────────────────────────────────── -->
        <categories
            jcr:primaryType="nt:unstructured"
            sling:resourceType="wcm/foundation/components/responsivegrid">
            <politics
                jcr:primaryType="nt:unstructured"
                sling:resourceType="newspaper/components/content/articlelisting"
                primaryTag="politics"
                maxItems="{Long}4"/>
            <sport
                jcr:primaryType="nt:unstructured"
                sling:resourceType="newspaper/components/content/articlelisting"
                primaryTag="sport"
                maxItems="{Long}4"/>
            <culture
                jcr:primaryType="nt:unstructured"
                sling:resourceType="newspaper/components/content/articlelisting"
                primaryTag="culture"
                maxItems="{Long}4"/>
            <technology
                jcr:primaryType="nt:unstructured"
                sling:resourceType="newspaper/components/content/articlelisting"
                primaryTag="technology"
                maxItems="{Long}4"/>
        </categories>

        <!-- ── XF Footer ──────────────────────────────────────────────── -->
        <experiencefragment-footer
            jcr:primaryType="nt:unstructured"
            sling:resourceType="newspaper/components/experiencefragment"
            fragmentVariationPath="/content/experience-fragments/newspaper/us/en/site/footer/master"/>

    </jcr:content>
</jcr:root>
