<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
          xmlns:cq="http://www.day.com/jcr/cq/1.0"
          xmlns:jcr="http://www.jcp.org/jcr/1.0"
          xmlns:nt="http://www.jcp.org/jcr/nt/1.0"
          jcr:primaryType="cq:Page">

    <jcr:content
        jcr:primaryType="cq:PageContent"
        cq:deviceGroups="[mobile/groups/responsive]"
        cq:template="/conf/newspaper/settings/wcm/templates/homepage"
        sling:resourceType="newspaper/components/structure/homepage">

        <!-- ── LOCKED: Header Experience Fragment ──────────────────────── -->
        <experiencefragment-header
            jcr:primaryType="nt:unstructured"
            sling:resourceType="newspaper/components/experiencefragment"
            fragmentVariationPath="/content/experience-fragments/newspaper/us/en/site/header/master"/>

        <!-- ── EDITABLE: Hero zone — 2-col featured articles ───────────── -->
        <!--
            Authors drop two article-listing components here;
            CSS (.homepage__hero .aem-Grid) enforces the 2-column layout.
        -->
        <hero
            jcr:primaryType="nt:unstructured"
            sling:resourceType="wcm/foundation/components/responsivegrid"
            editable="{Boolean}true"
            cq:policy="/conf/newspaper/settings/wcm/policies/newspaper/components/container/hero-zone"/>

        <!-- ── EDITABLE: Latest News zone — full-width grid ─────────────── -->
        <latest
            jcr:primaryType="nt:unstructured"
            sling:resourceType="wcm/foundation/components/responsivegrid"
            editable="{Boolean}true"
            cq:policy="/conf/newspaper/settings/wcm/policies/newspaper/components/container/main-zone"/>

        <!-- ── EDITABLE: Category sections — stacked listings ───────────── -->
        <categories
            jcr:primaryType="nt:unstructured"
            sling:resourceType="wcm/foundation/components/responsivegrid"
            editable="{Boolean}true"
            cq:policy="/conf/newspaper/settings/wcm/policies/newspaper/components/container/main-zone"/>

        <!-- ── LOCKED: Footer Experience Fragment ──────────────────────── -->
        <experiencefragment-footer
            jcr:primaryType="nt:unstructured"
            sling:resourceType="newspaper/components/experiencefragment"
            fragmentVariationPath="/content/experience-fragments/newspaper/us/en/site/footer/master"/>

        <!-- ── Responsive breakpoints ──────────────────────────────────── -->
        <cq:responsive jcr:primaryType="nt:unstructured">
            <breakpoints jcr:primaryType="nt:unstructured">
                <phone
                    jcr:primaryType="nt:unstructured"
                    title="Mobile (&lt;740 px)"
                    width="{Long}740"/>
                <tablet
                    jcr:primaryType="nt:unstructured"
                    title="Tablet (740–1140 px)"
                    width="{Long}1140"/>
                <desktop
                    jcr:primaryType="nt:unstructured"
                    title="Desktop (&gt;1140 px)"
                    width="{Long}1300"/>
            </breakpoints>
        </cq:responsive>

    </jcr:content>

</jcr:root>
