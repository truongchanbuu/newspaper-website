<?xml version="1.0" encoding="UTF-8"?>
<!-- // [ABC]
  Template Structure — Homepage
  Defines the locked framework that surrounds the editable zones.

  Node states:
    (no editable attr)   = LOCKED by template; page authors cannot add/remove/edit
    editable=true        = UNLOCKED; page authors can add components

  Zones in render order (matches homepage.html data-sly-resource keys):
    experiencefragment-header  LOCKED  — Guardian masthead
    hero                       editable — hero banner
    carousel                   editable — breaking-news teaser carousel
    main                       editable — stacked news listing sections
    experiencefragment-footer  LOCKED  — Guardian footer
-->
<jcr:root xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
          xmlns:cq="http://www.day.com/jcr/cq/1.0"
          xmlns:jcr="http://www.jcp.org/jcr/1.0"
          xmlns:nt="http://www.jcp.org/jcr/nt/1.0"
          jcr:primaryType="cq:Page">

    <jcr:content
        jcr:primaryType="cq:PageContent"
        cq:deviceGroups="[mobile/groups/responsive]"
        cq:template="/conf/newspaper/settings/wcm/templates/homepage"
        sling:resourceType="newspaper/components/structure/homepage">

        <!-- ── LOCKED: Header Experience Fragment ─────────────────── -->
        <experiencefragment-header
            jcr:primaryType="nt:unstructured"
            sling:resourceType="newspaper/components/experiencefragment"
            fragmentVariationPath="/content/experience-fragments/newspaper/us/en/site/header/master"
            cq:policy="/conf/newspaper/settings/wcm/policies/newspaper/components/experiencefragment/policy_header"/>

        <!-- ── EDITABLE: Hero banner zone ─────────────────────────── -->
        <hero
            jcr:primaryType="nt:unstructured"
            sling:resourceType="newspaper/components/container"
            editable="{Boolean}true"
            cq:policy="/conf/newspaper/settings/wcm/policies/newspaper/components/container/hero-zone"/>

        <!-- ── EDITABLE: Breaking news carousel ───────────────────── -->
        <carousel
            jcr:primaryType="nt:unstructured"
            sling:resourceType="newspaper/components/carousel"
            editable="{Boolean}true"
            autoplay="{Boolean}true"
            delay="{Long}5000"/>

        <!-- ── EDITABLE: Main news sections ───────────────────────── -->
        <main
            jcr:primaryType="nt:unstructured"
            sling:resourceType="newspaper/components/container"
            editable="{Boolean}true"
            cq:policy="/conf/newspaper/settings/wcm/policies/newspaper/components/container/main-zone"/>

        <!-- ── LOCKED: Footer Experience Fragment ─────────────────── -->
        <experiencefragment-footer
            jcr:primaryType="nt:unstructured"
            sling:resourceType="newspaper/components/experiencefragment"
            fragmentVariationPath="/content/experience-fragments/newspaper/us/en/site/footer/master"
            cq:policy="/conf/newspaper/settings/wcm/policies/newspaper/components/experiencefragment/policy_footer"/>

        <!-- ── Responsive breakpoints ─────────────────────────────── -->
        <cq:responsive jcr:primaryType="nt:unstructured">
            <breakpoints jcr:primaryType="nt:unstructured">
                <phone
                    jcr:primaryType="nt:unstructured"
                    title="Mobile (&lt;740 px)"
                    width="{Long}740"/>
                <tablet
                    jcr:primaryType="nt:unstructured"
                    title="Tablet (740–1140 px)"
                    width="{Long}1140"/>
                <desktop
                    jcr:primaryType="nt:unstructured"
                    title="Desktop (&gt;1140 px)"
                    width="{Long}1300"/>
            </breakpoints>
        </cq:responsive>

    </jcr:content>

</jcr:root>
