<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
          xmlns:cq="http://www.day.com/jcr/cq/1.0"
          xmlns:jcr="http://www.jcp.org/jcr/1.0"
          xmlns:nt="http://www.jcp.org/jcr/nt/1.0"
          jcr:primaryType="cq:Page">

    <jcr:content
        jcr:primaryType="nt:unstructured"
        sling:resourceType="wcm/core/components/policies/mappings">

        <!-- Page-level policy -->
        <jcr:content
            jcr:primaryType="nt:unstructured"
            cq:policy="/conf/newspaper/settings/wcm/policies/newspaper/components/page/policy"/>

        <!-- XF Header zone -->
        <experiencefragment-header
            jcr:primaryType="nt:unstructured"
            cq:policy="/conf/newspaper/settings/wcm/policies/newspaper/components/experiencefragment/policy_header"/>

        <!-- Hero zone container + its carousel children -->
        <hero
            jcr:primaryType="nt:unstructured"
            cq:policy="/conf/newspaper/settings/wcm/policies/newspaper/components/container/hero-zone">
            <carousel-left
                jcr:primaryType="nt:unstructured"
                cq:policy="/conf/newspaper/settings/wcm/policies/newspaper/components/content/carousel"/>
            <carousel-right
                jcr:primaryType="nt:unstructured"
                cq:policy="/conf/newspaper/settings/wcm/policies/newspaper/components/content/carousel"/>
            <articlecard
                jcr:primaryType="nt:unstructured"
                cq:policy="/conf/newspaper/settings/wcm/policies/newspaper/components/content/articlecard"
                sling:resourceType="wcm/core/components/policies/mapping"/>
        </hero>

        <!-- Latest News zone -->
        <latest
            jcr:primaryType="nt:unstructured"
            cq:policy="/conf/newspaper/settings/wcm/policies/newspaper/components/container/main-zone">
            <news-grid
                jcr:primaryType="nt:unstructured"
                cq:policy="/conf/newspaper/settings/wcm/policies/newspaper/components/content/articlelisting"/>
        </latest>

        <!-- Category sections zone -->
        <categories
            jcr:primaryType="nt:unstructured"
            cq:policy="/conf/newspaper/settings/wcm/policies/newspaper/components/container/main-zone">
            <politics
                jcr:primaryType="nt:unstructured"
                cq:policy="/conf/newspaper/settings/wcm/policies/newspaper/components/content/articlelisting"/>
            <sport
                jcr:primaryType="nt:unstructured"
                cq:policy="/conf/newspaper/settings/wcm/policies/newspaper/components/content/articlelisting"/>
            <culture
                jcr:primaryType="nt:unstructured"
                cq:policy="/conf/newspaper/settings/wcm/policies/newspaper/components/content/articlelisting"/>
            <technology
                jcr:primaryType="nt:unstructured"
                cq:policy="/conf/newspaper/settings/wcm/policies/newspaper/components/content/articlelisting"/>
            <articlecard
                jcr:primaryType="nt:unstructured"
                cq:policy="/conf/newspaper/settings/wcm/policies/newspaper/components/content/articlecard"
                sling:resourceType="wcm/core/components/policies/mapping"/>
        </categories>

        <!-- XF Footer zone -->
        <experiencefragment-footer
            jcr:primaryType="nt:unstructured"
            cq:policy="/conf/newspaper/settings/wcm/policies/newspaper/components/experiencefragment/policy_footer"/>

    </jcr:content>

</jcr:root>
