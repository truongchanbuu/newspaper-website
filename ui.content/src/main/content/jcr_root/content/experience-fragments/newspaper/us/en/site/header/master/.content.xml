<?xml version="1.0" encoding="UTF-8"?>
<!-- // [ABC]
  Header XF — Guardian masthead.
  Component order (CSS uses first-child / nth-child ordering):
    1. sitename  (text)              — "The Newspaper" wordmark → styled as the blue masthead logo
    2. navigation                    — section tabs (Politics, Tech, Sport …)
    3. languagenavigation            — globe icon + language picker
    4. search                        — search input
-->
<jcr:root xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
          xmlns:cq="http://www.day.com/jcr/cq/1.0"
          xmlns:jcr="http://www.jcp.org/jcr/1.0"
          xmlns:nt="http://www.jcp.org/jcr/nt/1.0"
          jcr:primaryType="cq:Page">
    <jcr:content
        cq:tags="[]"
        cq:template="/conf/newspaper/settings/wcm/templates/xf-web-variation"
        cq:xfMasterVariation="{Boolean}true"
        cq:xfVariantType="web"
        jcr:primaryType="cq:PageContent"
        jcr:title="Header"
        sling:resourceType="newspaper/components/xfpage">

        <root
            jcr:primaryType="nt:unstructured"
            sling:resourceType="newspaper/components/container"
            layout="simple">

            <!-- 1. Site wordmark — styled as the Guardian-blue logo bar -->
            <sitename
                jcr:primaryType="nt:unstructured"
                sling:resourceType="newspaper/components/text"
                text="&lt;p&gt;&lt;a href=&apos;/content/newspaper/us/en.html&apos;&gt;The Newspaper&lt;/a&gt;&lt;/p&gt;"
                textIsRich="{Boolean}true"/>

            <!-- 2. Primary navigation — section tabs -->
            <navigation
                jcr:primaryType="nt:unstructured"
                sling:resourceType="newspaper/components/navigation"
                collectAllPages="{Boolean}false"
                navigationRoot="/content/newspaper/us/en"
                skipNavigationRoot="{Boolean}false"
                structureDepth="{Long}1"
                accessibilityLabel="Primary"/>

            <!-- 3. Language navigation — positioned to the top-right via CSS -->
            <languagenavigation
                jcr:primaryType="nt:unstructured"
                sling:resourceType="newspaper/components/languagenavigation"
                navigationRoot="/content/newspaper/us"
                structureDepth="{Long}2"
                accessibilityLabel="Language"/>

            <!-- 4. Search -->
            <search
                jcr:primaryType="nt:unstructured"
                sling:resourceType="newspaper/components/search"
                searchRoot="/content/newspaper/us"
                searchTermMinimumLength="{Long}3"
                resultsSize="{Long}10"/>

        </root>
    </jcr:content>
</jcr:root>
