<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
          xmlns:cq="http://www.day.com/jcr/cq/1.0"
          xmlns:jcr="http://www.jcp.org/jcr/1.0"
          xmlns:nt="http://www.jcp.org/jcr/nt/1.0"
          jcr:primaryType="nt:unstructured"
          jcr:title="Carousel Slide"
          sling:resourceType="cq/gui/components/authoring/dialog">
    <content
        jcr:primaryType="nt:unstructured"
        sling:resourceType="granite/ui/components/coral/foundation/container">
        <items jcr:primaryType="nt:unstructured">
            <tabs
                jcr:primaryType="nt:unstructured"
                sling:resourceType="granite/ui/components/coral/foundation/tabs"
                maximized="{Boolean}true">
                <items jcr:primaryType="nt:unstructured">

                    <!--/* ── Tab 1: Article ──────────────────────────────────── */-->
                    <tabArticle
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Article"
                        sling:resourceType="granite/ui/components/coral/foundation/container"
                        margin="{Boolean}true">
                        <items jcr:primaryType="nt:unstructured">

                            <articlePath
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/pathfield"
                                fieldLabel="Article page"
                                fieldDescription="Select the article page to feature in this slide. Title, image, author and date are read automatically from the page."
                                name="./articlePath"
                                rootPath="/content/newspaper"
                                filter="hierarchyNotFile"
                                required="{Boolean}true"/>

                        </items>
                    </tabArticle>

                    <!--/* ── Tab 2: Overrides ────────────────────────────────── */-->
                    <tabOverrides
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Overrides"
                        sling:resourceType="granite/ui/components/coral/foundation/container"
                        margin="{Boolean}true">
                        <items jcr:primaryType="nt:unstructured">

                            <titleOverride
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                fieldLabel="Headline override"
                                fieldDescription="Leave blank to use the article page title."
                                name="./titleOverride"/>

                            <categoryLabel
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                fieldLabel="Category label override"
                                fieldDescription="Leave blank to use the category resolved from the article's tags and primaryTag. Example: 'Breaking News'."
                                name="./categoryLabel"/>

                        </items>
                    </tabOverrides>

                </items>
            </tabs>
        </items>
    </content>
</jcr:root>
