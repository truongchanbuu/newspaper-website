<?xml version="1.0" encoding="UTF-8"?>
<jcr:root
        xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
        xmlns:cq="http://www.day.com/jcr/cq/1.0"
        xmlns:jcr="http://www.jcp.org/jcr/1.0"
        xmlns:nt="http://www.jcp.org/jcr/nt/1.0"
        jcr:primaryType="nt:unstructured"
        jcr:title="Article Listing"
        sling:resourceType="cq/gui/components/authoring/dialog">

    <content
            jcr:primaryType="nt:unstructured"
            sling:resourceType="granite/ui/components/coral/foundation/container">
        <items jcr:primaryType="nt:unstructured">
            <tabs
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="granite/ui/components/coral/foundation/tabs"
                    maximized="{Boolean}true">

                <items jcr:primaryType="nt:unstructured">
                    <content
                            jcr:primaryType="nt:unstructured"
                            jcr:title="Content"
                            sling:resourceType="granite/ui/components/coral/foundation/container"
                            margin="{Boolean}true">

                        <items jcr:primaryType="nt:unstructured">

                            <!-- Category filter: matches the primaryTag slug on article pages -->
                            <primaryTag
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="granite/ui/components/coral/foundation/form/select"
                                    fieldLabel="Category (Primary Tag)"
                                    fieldDescription="Filter articles by category. Leave empty to show all categories."
                                    name="./primaryTag">
                                <items jcr:primaryType="nt:unstructured">
                                    <all
                                            jcr:primaryType="nt:unstructured"
                                            text="All categories"
                                            value=""
                                            selected="{Boolean}true"/>
                                    <business
                                            jcr:primaryType="nt:unstructured"
                                            text="Business"
                                            value="business"/>
                                    <culture
                                            jcr:primaryType="nt:unstructured"
                                            text="Culture"
                                            value="culture"/>
                                    <environment
                                            jcr:primaryType="nt:unstructured"
                                            text="Environment"
                                            value="environment"/>
                                    <lifestyle
                                            jcr:primaryType="nt:unstructured"
                                            text="Lifestyle"
                                            value="lifestyle"/>
                                    <politics
                                            jcr:primaryType="nt:unstructured"
                                            text="Politics"
                                            value="politics"/>
                                    <sport
                                            jcr:primaryType="nt:unstructured"
                                            text="Sport"
                                            value="sport"/>
                                    <technology
                                            jcr:primaryType="nt:unstructured"
                                            text="Technology"
                                            value="technology"/>
                                    <world
                                            jcr:primaryType="nt:unstructured"
                                            text="World"
                                            value="world"/>
                                </items>
                            </primaryTag>

                            <!-- Optional section heading override -->
                            <sectionTitle
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                    fieldLabel="Section Display Title"
                                    fieldDescription="Optional heading override. Leave empty to use the current page title."
                                    name="./sectionTitle" />

                            <!-- Max articles to display -->
                            <maxItems
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="granite/ui/components/coral/foundation/form/numberfield"
                                    fieldLabel="Number of Articles"
                                    fieldDescription="Maximum articles to display (1–24). Default: 6."
                                    name="./maxItems"
                                    value="6"
                                    min="1"
                                    max="24" />

                        </items>
                    </content>
                </items>
            </tabs>
        </items>
    </content>
</jcr:root>
