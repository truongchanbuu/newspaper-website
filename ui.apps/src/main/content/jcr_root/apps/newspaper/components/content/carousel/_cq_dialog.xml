<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
          xmlns:cq="http://www.day.com/jcr/cq/1.0"
          xmlns:jcr="http://www.jcp.org/jcr/1.0"
          xmlns:nt="http://www.jcp.org/jcr/nt/1.0"
          jcr:primaryType="nt:unstructured"
          jcr:title="Newspaper Carousel"
          sling:resourceType="cq/gui/components/authoring/dialog">
    <content
        jcr:primaryType="nt:unstructured"
        sling:resourceType="granite/ui/components/coral/foundation/container">
        <items jcr:primaryType="nt:unstructured">
            <tabs
                jcr:primaryType="nt:unstructured"
                sling:resourceType="granite/ui/components/coral/foundation/tabs"
                maximized="{Boolean}true">
                <items jcr:primaryType="nt:unstructured">

                    <!--/* Hide Core Carousel v1's inherited tabs — autoplay lives in our Settings tab */-->
                    <properties
                        jcr:primaryType="nt:unstructured"
                        sling:hideResource="{Boolean}true"/>
                    <accessibility
                        jcr:primaryType="nt:unstructured"
                        sling:hideResource="{Boolean}true"/>

                    <tabSettings
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Settings"
                        sling:resourceType="granite/ui/components/coral/foundation/container"
                        margin="{Boolean}true">
                        <items jcr:primaryType="nt:unstructured">

                            <source
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/select"
                                fieldLabel="Content source"
                                fieldDescription="Manual: author adds each slide via the component toolbar. Automatic: articles are pulled from search."
                                name="./source">
                                <items jcr:primaryType="nt:unstructured">
                                    <manual
                                        jcr:primaryType="nt:unstructured"
                                        text="Manual (authored slides)"
                                        value="manual"
                                        selected="{Boolean}true"/>
                                    <auto
                                        jcr:primaryType="nt:unstructured"
                                        text="Automatic (from search)"
                                        value="auto"/>
                                </items>
                            </source>

                            <primaryTag
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/select"
                                fieldLabel="Category"
                                fieldDescription="Automatic mode only. 'Latest' shows the most recent articles across all categories."
                                name="./primaryTag">
                                <items jcr:primaryType="nt:unstructured">
                                    <latest
                                        jcr:primaryType="nt:unstructured"
                                        text="Latest (all categories)"
                                        value=""
                                        selected="{Boolean}true"/>
                                    <politics
                                        jcr:primaryType="nt:unstructured"
                                        text="Politics"
                                        value="politics"/>
                                    <sport
                                        jcr:primaryType="nt:unstructured"
                                        text="Sport"
                                        value="sport"/>
                                    <culture
                                        jcr:primaryType="nt:unstructured"
                                        text="Culture"
                                        value="culture"/>
                                    <technology
                                        jcr:primaryType="nt:unstructured"
                                        text="Technology"
                                        value="technology"/>
                                    <world
                                        jcr:primaryType="nt:unstructured"
                                        text="World"
                                        value="world"/>
                                    <business
                                        jcr:primaryType="nt:unstructured"
                                        text="Business"
                                        value="business"/>
                                    <environment
                                        jcr:primaryType="nt:unstructured"
                                        text="Environment"
                                        value="environment"/>
                                    <lifestyle
                                        jcr:primaryType="nt:unstructured"
                                        text="Lifestyle"
                                        value="lifestyle"/>
                                </items>
                            </primaryTag>

                            <maxItems
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/numberfield"
                                fieldLabel="Max slides"
                                fieldDescription="Automatic mode only. Number of articles to display (1–10). Default: 5."
                                name="./maxItems"
                                value="5"
                                min="1"
                                max="10"/>

                            <autoplay
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/checkbox"
                                fieldLabel="Enable autoplay"
                                fieldDescription="Slides advance every 3 seconds. Pauses on hover and keyboard focus."
                                name="./autoplay"
                                value="{Boolean}true"/>

                        </items>
                    </tabSettings>

                </items>
            </tabs>
        </items>
    </content>
</jcr:root>
